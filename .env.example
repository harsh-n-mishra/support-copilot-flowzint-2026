OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
VECTOR_DB_DIR=.vectorstore
DOCS_DIR=data/docs
TOP_K=4
MEMORY_TURNS=6
MIN_RELEVANCE_SCORE=0.2
SUPPORT_EMAIL=support@example.com
SYSTEM_PROMPT=You are a support assistant. Answer only using retrieved context. Always include citations like [1], [2] that map to the provided sources. If the answer is not in context, say you do not know and trigger handoff.